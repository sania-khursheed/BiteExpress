rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidFoodItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() < 500 &&
             data.imageUrl is string && data.category is string;
    }

    // Food Items: Public read, Admin write
    match /foodItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidFoodItem(request.resource.data);
    }

    // Admins: Read-only for self
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
